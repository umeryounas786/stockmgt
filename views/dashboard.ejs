<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Stock Management</title>
    <link rel="stylesheet" href="/css/dashboard.css">
</head>
<body>
    <div class="dashboard-container">
        <!-- Sidebar -->
        <aside class="sidebar">
            <div class="sidebar-header">
                <h2>📦 Stock Manager</h2>
            </div>
            <nav class="sidebar-nav">
                <a href="/dashboard" class="nav-link active">Products</a>
                <a href="/companies" class="nav-link">Companies</a>
                <a href="/sales" class="nav-link">Sales</a>
                <a href="/logout" class="nav-link">Logout</a>
            </nav>
        </aside>

        <!-- Main Content -->
        <main class="main-content">
            <header class="header">
                <h1>Products &amp; Stock</h1>
                <div class="header-actions">
                    <button class="btn btn-primary" id="addProductBtn">+ Add Product</button>
                </div>
            </header>

            <section class="content-section">
                <h2>Stock In Hand</h2>
                <div class="table-container">
                    <table class="stock-table">
                        <thead>
                            <tr>
                                <th>Product Code</th>
                                <th>Description</th>
                                <th>Company</th>
                                <th>Packet Size</th>
                                <th>Purchased</th>
                                <th>Total Sold</th>
                                <th>Stock In Hand</th>
                                <th>In Boxes</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody id="productTableBody">
                            <!-- Populated by JavaScript -->
                        </tbody>
                    </table>
                </div>
            </section>
        </main>
    </div>

    <!-- Add/Edit Product Modal -->
    <div id="productModal" class="modal">
        <div class="modal-content">
            <span class="close">&times;</span>
            <h2 id="productModalTitle">Add Product</h2>
            <form id="productForm">
                <div class="form-group">
                    <label for="companyId">Company *</label>
                    <select id="companyId" name="companyId" required>
                        <option value="">-- Select Company --</option>
                    </select>
                </div>

                <div class="form-group">
                    <label for="productCode">Product Code</label>
                    <input type="text" id="productCode" name="productCode"
                           placeholder="Auto-generated from company" readonly>
                </div>

                <div class="form-group">
                    <label for="description">Description</label>
                    <input type="text" id="description" name="description" placeholder="e.g. toys">
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label for="packetSize">Packet Size *</label>
                        <input type="number" id="packetSize" name="packetSize" min="1" value="1" required>
                    </div>
                    <div class="form-group">
                        <label for="stockPurchase">Stock Purchased *</label>
                        <input type="number" id="stockPurchase" name="stockPurchase" min="0" value="0" required>
                    </div>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">Save Product</button>
                    <button type="button" class="btn btn-secondary" id="productCancelBtn">Cancel</button>
                </div>
            </form>
        </div>
    </div>

    <script src="/js/dashboard.js"></script>
</body>
</html>
