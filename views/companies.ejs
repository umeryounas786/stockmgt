<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Companies - Stock Management</title>
    <link rel="stylesheet" href="/css/dashboard.css">
</head>
<body>
    <div class="dashboard-container">
        <!-- Sidebar -->
        <aside class="sidebar">
            <div class="sidebar-header">
                <h2>📦 Stock Manager</h2>
            </div>
            <nav class="sidebar-nav">
                <a href="/dashboard" class="nav-link">Products</a>
                <a href="/companies" class="nav-link active">Companies</a>
                <a href="/sales" class="nav-link">Sales</a>
                <a href="/logout" class="nav-link">Logout</a>
            </nav>
        </aside>

        <!-- Main Content -->
        <main class="main-content">
            <header class="header">
                <h1>Companies</h1>
                <div class="header-actions">
                    <button class="btn btn-primary" id="addCompanyBtn">+ Add Company</button>
                </div>
            </header>

            <section class="content-section">
                <h2>All Companies</h2>
                <div class="table-container">
                    <table class="stock-table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Code</th>
                                <th>Name</th>
                                <th>Products</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody id="companyTableBody">
                            <!-- Populated by JavaScript -->
                        </tbody>
                    </table>
                </div>
            </section>
        </main>
    </div>

    <!-- Add/Edit Company Modal -->
    <div id="companyModal" class="modal">
        <div class="modal-content">
            <span class="close">&times;</span>
            <h2 id="companyModalTitle">Add Company</h2>
            <form id="companyForm">
                <div class="form-group">
                    <label for="companyCode">Company Code *</label>
                    <input type="text" id="companyCode" name="companyCode" placeholder="e.g. sam" required>
                </div>

                <div class="form-group">
                    <label for="companyName">Company Name *</label>
                    <input type="text" id="companyName" name="companyName" placeholder="e.g. samtajir" required>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">Save Company</button>
                    <button type="button" class="btn btn-secondary" id="companyCancelBtn">Cancel</button>
                </div>
            </form>
        </div>
    </div>

    <script src="/js/companies.js"></script>
</body>
</html>
